# Backend
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
ARXIV_TIMEOUT_SECONDS=10
SEMANTIC_SCHOLAR_API_KEY=
RESEARCHPILOT_DEMO_MODE=false

# Supabase / pgvector-ready research memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_NOTES_TABLE=research_notes

# Research tool adapter
# local = direct Python tool functions
# mcp_single = start a stdio MCP server per call
# mcp_persistent = reuse one stdio MCP session
RESEARCH_TOOL_CLIENT_MODE=local
MCP_SERVER_COMMAND=
MCP_SERVER_ARGS=mcp_server/server.py
MCP_SERVER_CWD=
MCP_FALLBACK_TO_LOCAL=true
MCP_STARTUP_TIMEOUT_SECONDS=10
MCP_CALL_TIMEOUT_SECONDS=30

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
